# CypressBit Transportation I-O Modeling Lab — Environment Variables
# Copy this file to .env and populate as needed.
# The .env file is git-ignored and should never be committed.

# -----------------------------------------------------------------------------
# Data and Output Directories
# -----------------------------------------------------------------------------

# Override the default data directory (default: data/sample/)
# CB_IO_DATA_DIR=data/sample

# Override the default output directory (default: outputs/)
# CB_IO_OUTPUT_DIR=outputs

# -----------------------------------------------------------------------------
# External API Keys (Placeholder — adapters not yet implemented)
# -----------------------------------------------------------------------------

# BEA (Bureau of Economic Analysis) API key
# Required only if BEADataAdapter is implemented.
# Register at: https://apps.bea.gov/API/signup/
# BEA_API_KEY=your_bea_api_key_here

# BLS (Bureau of Labor Statistics) API key
# Required only if BLSDataAdapter is implemented.
# Register at: https://www.bls.gov/developers/
# BLS_API_KEY=your_bls_api_key_here
